<odoo>

    <!-- List View -->
    <record id="view_product_list" model="ir.ui.view">
        <field name="name">shop.product.list</field>
        <field name="model">shop.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="price"/>
                <field name="quantity"/>
                <field name="category"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_product_form" model="ir.ui.view">
        <field name="name">shop.product.form</field>
        <field name="model">shop.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="price"/>
                        <field name="quantity"/>
                        <field name="category"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
      <record id="view_product_form_stock" model="ir.ui.view">
        <field name="name">shop.product.form.stock</field>
        <field name="model">shop.product</field>
        <field name="inherit_id" ref="shop_product.view_product_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group" position="inside">
                <field name="quantity"/>
                <field name="is_out_of_stock" readonly="1"/>
            </xpath>

        </field>
    </record>

    <!-- Action -->
    <record id="action_product" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">shop.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->

    <!-- Product Menu -->
    <menuitem id="menu_product"
            name="Products"
            parent="shop_base.menu_shop_root"
            action="action_product"/>

</odoo>