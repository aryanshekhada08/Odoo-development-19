<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Root Menu ─────────────────────────────────── -->
    <menuitem
        id="menu_library_root"
        name="Library"
        sequence="10"
        web_icon="library_management,static/description/icon.png"/>

    <!-- ─── Books Menu ───────────────────────────────── -->
    <menuitem
        id="menu_library_books"
        name="Books"
        parent="menu_library_root"
        sequence="10"/>

    <menuitem
        id="menu_library_book_list"
        name="All Books"
        parent="menu_library_books"
        action="action_library_book"
        sequence="10"/>

    <!-- ─── Members Menu ─────────────────────────────── -->
    <menuitem
        id="menu_library_members"
        name="Members"
        parent="menu_library_root"
        sequence="20"/>

    <menuitem
        id="menu_library_member_list"
        name="All Members"
        parent="menu_library_members"
        action="action_library_member"
        sequence="10"/>

    <!-- ─── Borrowing Menu ───────────────────────────── -->
    <menuitem
        id="menu_library_borrows"
        name="Borrowing"
        parent="menu_library_root"
        sequence="30"/>

    <menuitem
        id="menu_library_borrow_list"
        name="All Borrows"
        parent="menu_library_borrows"
        action="action_library_borrow"
        sequence="10"/>

    <!-- ─── Fines Menu ───────────────────────────────── -->
    <menuitem
        id="menu_library_fines"
        name="Fines"
        parent="menu_library_root"
        sequence="40"/>

    <menuitem
        id="menu_library_fine_list"
        name="All Fines"
        parent="menu_library_fines"
        action="action_library_fine"
        sequence="10"/>

</odoo>