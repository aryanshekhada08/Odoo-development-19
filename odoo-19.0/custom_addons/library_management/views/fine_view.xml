<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── LIST VIEW ────────────────────────────────── -->
    <record id="view_library_fine_list" model="ir.ui.view">
        <field name="name">library.fine.list</field>
        <field name="model">library.fine</field>
        <field name="arch" type="xml">
            <list string="Fines"
                  decoration-success="state == 'paid'"
                  decoration-warning="state == 'partial'"
                  decoration-danger="state == 'unpaid'">

                <field name="reference"/>
                <field name="member_id"/>
                <field name="borrow_id"/>
                <field name="amount"/>
                <field name="paid_amount"/>
                <field name="remaining_amount"/>
                <field name="payment_date"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-warning="state == 'partial'"
                       decoration-danger="state == 'unpaid'"/>

            </list>
        </field>
    </record>

    <!-- ─── FORM VIEW ────────────────────────────────── -->
    <record id="view_library_fine_form" model="ir.ui.view">
        <field name="name">library.fine.form</field>
        <field name="model">library.fine</field>
        <field name="arch" type="xml">
            <form string="Fine">
                <header>

                    <button name="action_pay_full"
                            string="Mark as Fully Paid"
                            type="object"
                            class="btn-success"
                            groups="library_management.group_library_manager"
                            invisible="state == 'paid'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="unpaid,partial,paid"/>

                </header>

                <sheet>

                    <widget name="web_ribbon"
                            title="Paid ✓"
                            bg_color="bg-success"
                            invisible="state != 'paid'"/>

                    <widget name="web_ribbon"
                            title="Unpaid!"
                            bg_color="bg-danger"
                            invisible="state != 'unpaid'"/>

                    <div class="oe_button_box" name="button_box">

                        <button class="oe_stat_button"
                                icon="fa-money"
                                type="object"
                                name="action_pay_full"
                                groups="library_management.group_library_manager"
                                invisible="state == 'paid'">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="amount"/>
                                </span>
                                <span class="o_stat_text">Total Fine</span>
                            </div>
                        </button>

                        <button class="oe_stat_button"
                                icon="fa-check-circle"
                                type="object"
                                name="action_pay_full"
                                groups="library_management.group_library_manager"
                                invisible="paid_amount == 0">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="paid_amount"/>
                                </span>
                                <span class="o_stat_text">Paid</span>
                            </div>
                        </button>

                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="📋 Fine Details">
                            <field name="member_id" readonly="1"/>
                            <field name="borrow_id" readonly="1"/>
                            <field name="amount" readonly="1"/>
                        </group>
                        <group string="💰 Payment Info">
                            <field name="paid_amount" readonly="1"/>
                            <field name="remaining_amount" readonly="1"/>
                            <field name="payment_date" readonly="1"/>
                        </group>
                    </group>

                    <group string="💳 Payment Progress">
                        <field name="paid_amount"
                               widget="progressbar"
                               options="{'max_value': 'amount', 'current_value': 'paid_amount', 'editable': False}"
                               nolabel="1"/>
                    </group>

                    <div class="alert alert-success mb-3"
                         invisible="state != 'paid'"
                         role="alert">
                        <strong>✅ Fine Fully Paid!</strong>
                        Payment received on
                        <field name="payment_date"
                               readonly="1"
                               nolabel="1"
                               class="d-inline"/>
                        Member has been automatically unblocked.
                    </div>

                    <div class="alert alert-danger mb-3"
                         invisible="state != 'unpaid'"
                         role="alert">
                        <strong>⚠️ Payment Pending!</strong>
                        This member is blocked until fine is paid.
                        Remaining:
                        <field name="remaining_amount"
                               readonly="1"
                               nolabel="1"
                               class="d-inline"/>
                    </div>

                    <group string="📝 Notes">
                        <field name="notes"
                               nolabel="1"
                               placeholder="Add payment notes here..."/>
                    </group>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── SEARCH VIEW ──────────────────────────────── -->
    <record id="view_library_fine_search" model="ir.ui.view">
        <field name="name">library.fine.search</field>
        <field name="model">library.fine</field>
        <field name="arch" type="xml">
            <search string="Search Fines">

                <field name="reference"/>
                <field name="member_id"/>
                <field name="borrow_id"/>

                <filter string="Unpaid"
                        name="filter_unpaid"
                        domain="[('state', '=', 'unpaid')]"/>

                <filter string="Partially Paid"
                        name="filter_partial"
                        domain="[('state', '=', 'partial')]"/>

                <filter string="Paid"
                        name="filter_paid"
                        domain="[('state', '=', 'paid')]"/>

                <separator/>

                <filter string="High Fines"
                        name="filter_high"
                        domain="[('amount', '>=', 50)]"/>

                <separator/>

                <filter string="Group By Member"
                        name="group_member"
                        context="{'group_by': 'member_id'}"/>

                <filter string="Group By Status"
                        name="group_state"
                        context="{'group_by': 'state'}"/>

                <filter string="Group By Payment Date"
                        name="group_payment_date"
                        context="{'group_by': 'payment_date:month'}"/>

            </search>
        </field>
    </record>

    <!-- ─── ACTION ───────────────────────────────────── -->
    <record id="action_library_fine" model="ir.actions.act_window">
        <field name="name">Fines</field>
        <field name="res_model">library.fine</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_library_fine_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No fines yet!
            </p>
            <p>
                Fines are created automatically when books are returned late.
            </p>
        </field>
    </record>

</odoo>
