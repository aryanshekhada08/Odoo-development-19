<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── LIST VIEW ────────────────────────────────── -->
    <record id="view_library_member_list" model="ir.ui.view">
        <field name="name">library.member.list</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list string="Members"
                  decoration-success="state == 'active'"
                  decoration-danger="state == 'blocked'"
                  decoration-muted="state == 'expired'">

                <field name="membership_number"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="active_borrows"/>
                <field name="expiry_date"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'blocked'"
                       decoration-warning="state == 'expired'"/>

            </list>
        </field>
    </record>

    <!-- ─── FORM VIEW ────────────────────────────────── -->
    <record id="view_library_member_form" model="ir.ui.view">
        <field name="name">library.member.form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form string="Member">
                <header>

                    <button name="action_block"
                            string="Block Member"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'blocked' or state == 'expired'"/>

                    <button name="action_unblock"
                            string="Unblock"
                            type="object"
                            class="btn-success"
                            invisible="state != 'blocked'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="active,expired,blocked"/>

                </header>

                <sheet>

                    <!-- ── Stat Buttons ── -->
                    <div class="oe_button_box" name="button_box">

                        <button name="action_library_borrow"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-book">
                            <field name="active_borrows"
                                   widget="statinfo"
                                   string="Active Borrows"/>
                        </button>

                        <button name="action_library_borrow"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-history">
                            <field name="total_borrowed"
                                   widget="statinfo"
                                   string="Total Borrowed"/>
                        </button>

                    </div>

                    <!-- ── Avatar + Name ── -->
                    <widget name="web_ribbon"
                            title="Blocked"
                            bg_color="bg-danger"
                            invisible="state != 'blocked'"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   placeholder="Member Name..."/>
                        </h1>
                        <h4 style="color: #888;">
                            <field name="membership_number"
                                   readonly="1"/>
                        </h4>
                    </div>

                    <!-- ── Main Fields ── -->
                    <group>
                        <group string="📋 Personal Info">
                            <field name="email"
                                   widget="email"/>
                            <field name="phone"
                                   widget="phone"/>
                            <field name="street"
                                   placeholder="Street..."/>
                            <field name="city"
                                   placeholder="City..."/>
                        </group>
                        <group string="🎫 Membership">
                            <field name="membership_date"/>
                            <field name="expiry_date"/>
                            <field name="is_blocked"
                                   widget="boolean_toggle"/>
                        </group>
                    </group>

                    <!-- ── Block Reason ── -->
                    <group invisible="not is_blocked">
                        <field name="block_reason"
                               placeholder="Reason for blocking this member..."
                               nolabel="1"/>
                    </group>

                    <!-- ── Chatter ── -->
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── SEARCH VIEW ──────────────────────────────── -->
    <record id="view_library_member_search" model="ir.ui.view">
        <field name="name">library.member.search</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <search string="Search Members">

                <field name="name"/>
                <field name="membership_number"/>
                <field name="email"/>
                <field name="phone"/>

                <filter string="Active"
                        name="filter_active"
                        domain="[('state', '=', 'active')]"/>

                <filter string="Blocked"
                        name="filter_blocked"
                        domain="[('state', '=', 'blocked')]"/>

                <filter string="Expired"
                        name="filter_expired"
                        domain="[('state', '=', 'expired')]"/>

                <filter string="Has Active Borrows"
                        name="filter_has_borrows"
                        domain="[('active_borrows', '>', 0)]"/>

                <separator/>

                <group expand="0" string="Group By">
                    <filter string="Status"
                            name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Member Since"
                            name="group_membership_date"
                            context="{'group_by': 'membership_date:month'}"/>
                </group>

            </search>
        </field>
    </record>

    <!-- ─── ACTION ───────────────────────────────────── -->
    <record id="action_library_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_library_member_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first member!
            </p>
            <p>
                Add library members to start tracking borrowing activity.
            </p>
        </field>
    </record>

</odoo>