<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_library_member_user" model="res.groups">
        <field name="name">Library Member User</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_library_manager" model="res.groups">
        <field name="name">Library Manager</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('library_management.group_library_member_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
