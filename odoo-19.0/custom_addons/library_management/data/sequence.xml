<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Book Sequence -->
    <record id="sequence_library_book" model="ir.sequence">
        <field name="name">Library Book</field>
        <field name="code">library.book</field>
        <field name="prefix">LB/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
    </record>

    <!-- Member Sequence -->
    <record id="sequence_library_member" model="ir.sequence">
        <field name="name">Library Member</field>
        <field name="code">library.member</field>
        <field name="prefix">LM/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
    </record>

    <!-- Borrow Sequence -->
    <record id="sequence_library_borrow" model="ir.sequence">
        <field name="name">Library Borrow</field>
        <field name="code">library.borrow</field>
        <field name="prefix">LBR/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
    </record>

    <!-- Fine Sequence -->
    <record id="sequence_library_fine" model="ir.sequence">
        <field name="name">Library Fine</field>
        <field name="code">library.fine</field>
        <field name="prefix">LF/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
    </record>

</odoo>