<odoo>

    <!-- ===================== -->
    <!-- SALE LIST VIEW -->
    <!-- ===================== -->
    <record id="view_sale_list" model="ir.ui.view">
        <field name="name">shop.sale.list</field>
        <field name="model">shop.sale</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- ===================== -->
    <!-- SALE LINE LIST VIEW -->
    <!-- ===================== -->
    <record id="view_sale_line_list" model="ir.ui.view">
        <field name="name">shop.sale.line.list</field>
        <field name="model">shop.sale.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="price" readonly="1"/>
                <field name="subtotal" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- ===================== -->
    <!-- SALE FORM VIEW -->
    <!-- ===================== -->
    <record id="view_sale_form" model="ir.ui.view">
        <field name="name">shop.sale.form</field>
        <field name="model">shop.sale</field>
        <field name="arch" type="xml">
            <form>
               <header>
                    <!-- CONFIRM -->
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <!-- DONE -->
                    <button name="action_done"
                            string="Mark as Done"
                            type="object"
                            class="btn-success"
                            invisible="state != 'confirmed'"/>

                    <!-- CANCEL -->
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'cancel'"/>

                    <!-- RESET -->
                    <button name="action_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state == 'draft'"/>

                    <field name="state" widget="statusbar"/>
                     <button name="action_create_invoice"
                            string="Create Invoice"
                            type="object"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">

                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file">

                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                            
                        </button>

                    </div>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="customer_id"/>
                    </group>

                    <notebook>

                        <!-- 🔥 ORDER LINES TAB -->
                        <page string="Order Lines">
                            <field name="order_line">
                                <list editable="bottom">
                                    
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price" readonly="1"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                            </field>
                        </page>

                    </notebook>

                    <group>
                        <field name="total" readonly="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ===================== -->
    <!-- ACTION -->
    <!-- ===================== -->
    <record id="action_sale" model="ir.actions.act_window">
        <field name="name">Sales</field>
        <field name="res_model">shop.sale</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== -->
    <!-- MENU -->
    <!-- ===================== -->
    <menuitem id="menu_sale"
              name="Sales"
              parent="shop_base.menu_shop_root"
              action="action_sale"/>

</odoo>