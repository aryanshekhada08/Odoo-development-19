<odoo>

    <!-- List View -->
    <record id="view_sale_list" model="ir.ui.view">
        <field name="name">shop.sale.list</field>
        <field name="model">shop.sale</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="price"/>
                <field name="total"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sale_form" model="ir.ui.view">
        <field name="name">shop.sale.form</field>
        <field name="model">shop.sale</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="customer_id"/>
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="price" readonly="1"/>
                        <field name="total" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sale" model="ir.actions.act_window">
        <field name="name">Sales</field>
        <field name="res_model">shop.sale</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_sale"
              name="Sales"
              parent="shop_base.menu_shop_root"   
              action="action_sale"/>

</odoo>