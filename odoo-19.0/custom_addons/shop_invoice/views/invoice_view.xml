<odoo>

    <!-- LIST VIEW -->
    <record id="view_invoice_list" model="ir.ui.view">
        <field name="name">shop.invoice.list</field>
        <field name="model">shop.invoice</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sale_id"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_invoice_form" model="ir.ui.view">
        <field name="name">shop.invoice.form</field>
        <field name="model">shop.invoice</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_paid"
                            string="Mark as Paid"
                            type="object"
                            class="btn-success"
                            invisible="state == 'paid'"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="sale_id"/>
                        <field name="amount" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_invoice" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">shop.invoice</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_invoice"
              name="Invoices"
              parent="shop_base.menu_shop_root"
              action="action_invoice"/>

</odoo>