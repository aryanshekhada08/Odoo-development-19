<odoo>

    <record id="view_dashboard_form" model="ir.ui.view">
        <field name="name">shop.dashboard.form</field>
        <field name="model">shop.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard" create="0" delete="0">
                <sheet class="dashboard-shell">
                    <div class="oe_title">
                        <h1>Business Dashboard</h1>
                        <div class="dashboard-subtitle">Track sales, customers, and product performance in one place.</div>
                    </div>

                    <div class="row mt16">
                        <div class="col-lg-4">
                            <div class="kpi-card kpi-blue">
                                <div class="o_stat_value">
                                    <field name="total_sales"/>
                                </div>
                                <div>Total Orders</div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="kpi-card kpi-green">
                                <div class="o_stat_value">
                                    <field name="total_revenue"/>
                                </div>
                                <div>Total Revenue</div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="kpi-card kpi-orange">
                                <div class="o_stat_value">
                                    <field name="total_customers"/>
                                </div>
                                <div>Total Customers</div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt24">
                        <div class="col-lg-6 mb-3">
                            <div class="dashboard-panel panel-blue">
                                <div class="dashboard-panel-title">Sales Overview</div>
                                <div class="dashboard-panel-body">
                                    <field name="chart_data" widget="dashboard_graph" graph_type="bar" nolabel="1"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 mb-3">
                            <div class="dashboard-panel panel-orange">
                                <div class="dashboard-panel-title">Top Products</div>
                                <div class="dashboard-panel-body">
                                    <field name="top_products_data" widget="dashboard_graph" graph_type="bar" nolabel="1"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dashboard_server" model="ir.actions.server">
        <field name="name">Dashboard</field>
        <field name="model_id" ref="model_shop_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

    <menuitem id="menu_dashboard"
              name="Dashboard"
              parent="shop_base.menu_shop_root"
              action="action_dashboard_server"
              sequence="1"/>

</odoo>
