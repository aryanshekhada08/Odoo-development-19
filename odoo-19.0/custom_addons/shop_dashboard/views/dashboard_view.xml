<odoo>

    <record id="view_dashboard_form" model="ir.ui.view">
        <field name="name">shop.dashboard.form</field>
        <field name="model">shop.dashboard</field>
        <field name="arch" type="xml">

            <form string="Dashboard">
                <sheet>

                    <!-- HEADER -->
                    <div class="oe_title">
                        <h1>📊 Business Dashboard</h1>
                    </div>

                    <!-- KPI CARDS -->
                    <div class="row mt16">

                        <div class="col-lg-4">
                            <div class="o_stat_box bg-primary text-white p-3 rounded">
                                <div class="o_stat_value">
                                    <field name="total_sales"/>
                                </div>
                                <div class="o_stat_text">
                                    🛒 Total Orders
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="o_stat_box bg-success text-white p-3 rounded">
                                <div class="o_stat_value">
                                    <field name="total_revenue"/>
                                </div>
                                <div class="o_stat_text">
                                    💰 Total Revenue
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="o_stat_box bg-warning text-white p-3 rounded">
                                <div class="o_stat_value">
                                    <field name="total_customers"/>
                                </div>
                                <div class="o_stat_text">
                                    👤 Total Customers
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- SPACING -->
                    <div class="mt32"/>

                    <!-- CHART SECTION -->
                    <group>

                        <!-- HIDDEN DATA -->
                        <field name="chart_data" />

                        <div class="o_form_label">
                            <h2>📊 Monthly Sales Analytics</h2>
                        </div>

                        <div style="width:100%; text-align:center;">
                            <canvas id="salesChart" style="max-width:900px;height:300px;"></canvas>
                        </div>

                        <!-- SAFE SCRIPT -->
                        <script type="text/javascript">
                            setTimeout(function () {

                                const dataField = document.querySelector('[name="chart_data"]');

                                if (!dataField) return;

                                let chartData = {};

                                try {
                                    chartData = JSON.parse(dataField.value || dataField.textContent || "{}");
                                } catch (e) {}

                                const ctx = document.getElementById('salesChart');

                                if (ctx &amp;&amp; chartData.labels) {
                                    new Chart(ctx, {
                                        type: 'bar',
                                        data: {
                                            labels: chartData.labels,
                                            datasets: [{
                                                label: "Monthly Sales",
                                                data: chartData.values,
                                            }]
                                        },
                                        options: {
                                            responsive: true,
                                            plugins: {
                                                legend: {
                                                    display: true
                                                }
                                            }
                                        }
                                    });
                                }

                            }, 1200);
                        </script>

                    </group>
                    <group>
                        <field name="top_products_data" />

                        <div class="o_form_label">
                            <h2>🥧 Top Products</h2>
                        </div>

                        <div style="width:100%; text-align:center;">
                            <canvas id="productPieChart" style="max-width:600px;height:300px;"></canvas>
                        </div>
                       <script type="text/javascript">
                            setTimeout(function () {

                                const el = document.querySelector('[name="top_products_data"]');
                                if (!el) return;

                                let data = {};

                                try {
                                    data = JSON.parse(el.value || el.textContent || "{}");
                                } catch (e) {
                                    console.log("Pie JSON error", e);
                                }

                                const ctx = document.getElementById('productPieChart');

                                if (ctx &amp;&amp; data.labels) {
                                    new Chart(ctx, {
                                        type: 'pie',
                                        data: {
                                            labels: data.labels,
                                            datasets: [{
                                                data: data.values,
                                            }]
                                        }
                                    });
                                }

                            }, 500);
                        </script>
                    </group>
                </sheet>
            </form>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">shop.dashboard</field>
        <field name="view_mode">form</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_dashboard"
              name="Dashboard"
              parent="shop_base.menu_shop_root"
              action="action_dashboard"
              sequence="1"/>

</odoo>