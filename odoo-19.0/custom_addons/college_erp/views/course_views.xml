<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="course_tree_view" model="ir.ui.view">
        <field name="name">college.course.tree</field>
        <field name="model">college.course</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="duration"/>
            </list>
        </field>
    </record>

    <record id="course_form_view" model="ir.ui.view">
        <field name="name">college.course.form</field>
        <field name="model">college.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="duration"/>
                        <field name="student_ids" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="course_action" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">college.course</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
