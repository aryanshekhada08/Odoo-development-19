<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="student_list_view" model="ir.ui.view">
        <field name="name">college.student.list</field>
        <field name="model">college.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="enrollment_number"/>
                <field name="course_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="student_form_view" model="ir.ui.view">
        <field name="name">college.student.form</field>
        <field name="model">college.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="enrollment_number"/>
                        <field name="course_id"/>
                        <field name="admission_date"/>
                        <field name="date_of_birth"/>
                        <field name="age"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="student_action" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">college.student</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
