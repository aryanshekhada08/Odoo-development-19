<odoo>
    <record id="view_lost_item_tree" model="ir.ui.view">
        <field name="name">lost.item.tree</field>
        <field name="model">student.lost.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="student_id"/>
                <field name="lost_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_lost_item_form" model="ir.ui.view">
        <field name="name">lost.item.form</field>
        <field name="model">student.lost.item</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_found"
                            type="object"
                            string="Mark Found"
                            states="lost"/>

                    <button name="action_verify"
                            type="object"
                            string="Verify"
                            states="found"/>

                    <button name="action_return"
                            type="object"
                            string="Return"
                            states="verified"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="student_id"/>
                        <field name="lost_date"/>
                        <field name="location"/>
                        <field name="found_by"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- ACTION -->
<record id="action_lost_item" model="ir.actions.act_window">
    <field name="name">Lost Items</field>
    <field name="res_model">student.lost.item</field>
    <field name="view_mode">tree,form</field>
</record>

<!-- MENU -->
<menuitem id="menu_student_root" name="Student Management"/>

<menuitem id="menu_lost_item"
          name="Lost & Found"
          parent="menu_student_root"
          action="action_lost_item"/>

</odoo>
