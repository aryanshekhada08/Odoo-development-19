<odoo>

    <!-- Tree View -->
    <record id="view_customer_tree" model="ir.ui.view">
        <field name="name">shop.customer.tree</field>
        <field name="model">shop.customer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_customer_form" model="ir.ui.view">
        <field name="name">shop.customer.form</field>
        <field name="model">shop.customer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="address"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_customer" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">shop.customer</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_customer"
              name="Customers"
              parent="shop_base.menu_shop_root"
              action="action_customer"/>

</odoo>