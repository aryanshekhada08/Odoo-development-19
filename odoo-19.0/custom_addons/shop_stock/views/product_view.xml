<odoo>

    <record id="view_product_form_stock" model="ir.ui.view">
        <field name="name">shop.product.form.stock</field>
        <field name="model">shop.product</field>
        <field name="inherit_id" ref="shop_product.view_product_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group" position="inside">
                <field name="quantity"/>
                <field name="is_out_of_stock" readonly="1"/>
            </xpath>

        </field>
    </record>

</odoo>